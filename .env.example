# PteroMCP configuration. Copy this file to `.env` and fill in real values.

# Base URL of your panel (Pterodactyl or Pelican). No trailing slash.
PTEROMCP_PANEL_URL=https://panel.example.com

# Application API key (admin scope). Usually starts with `ptla_` (Pterodactyl)
# or `papp_` (Pelican). Required for /api/application/* endpoints.
PTEROMCP_APPLICATION_KEY=papp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional client API key (user scope). Starts with `ptlc_` on both panels
# (Pelican kept the Pterodactyl convention). Only needed when calling
# /api/client/* tools.
PTEROMCP_CLIENT_KEY=

# Panel flavor: "auto" (detect at startup), "pterodactyl" or "pelican".
PTEROMCP_PANEL_TYPE=auto

# HTTP timeout in seconds.
PTEROMCP_TIMEOUT=30

# When `true`, the server refuses any mutating tool call (POST/PATCH/PUT/DELETE).
# Useful for safe exploration.
PTEROMCP_READ_ONLY=false

# Comma-separated list of additional tool categories to disable.
# Valid values: users, nodes, servers, eggs, roles, mounts, databases, allocations, client
# PTEROMCP_DISABLED_CATEGORIES=
